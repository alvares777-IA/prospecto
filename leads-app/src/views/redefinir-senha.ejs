<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nova senha — Prospecto-IA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #080c18; color: #e2e8f0;
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center; padding: 20px;
    }
    body::before {
      content: ''; position: fixed; inset: 0;
      background: radial-gradient(ellipse 60% 50% at 50% -10%, rgba(0,240,255,0.1), transparent),
                  radial-gradient(ellipse 50% 40% at 80% 80%, rgba(139,92,246,0.08), transparent);
      pointer-events: none;
    }
    .card {
      width: 100%; max-width: 380px;
      background: #0d1224; border: 1px solid #1e2a45; border-radius: 16px;
      padding: 36px 32px; position: relative; z-index: 1;
      box-shadow: 0 0 60px rgba(0,240,255,0.05), 0 25px 50px rgba(0,0,0,0.5);
    }
    .card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0;
      height: 2px; border-radius: 16px 16px 0 0;
      background: linear-gradient(90deg, #00f0ff, #8b5cf6);
    }
    .logo-wrap { text-align: center; margin-bottom: 28px; }
    .logo-icon {
      display: inline-flex; align-items: center; justify-content: center;
      width: 52px; height: 52px;
      background: linear-gradient(135deg, #00f0ff, #8b5cf6);
      border-radius: 14px; font-size: 24px; color: #000;
      box-shadow: 0 0 20px rgba(0,240,255,0.3); margin-bottom: 14px;
    }
    .logo-title { font-size: 18px; font-weight: 700; color: #e2e8f0; }
    .logo-sub { font-size: 12px; color: #475569; margin-top: 4px; }
    .alert { padding: 10px 14px; border-radius: 8px; font-size: 13px; display: flex; align-items: center; gap: 8px; margin-bottom: 18px; }
    .alert-danger  { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
    .alert-success { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3); color: #6ee7b7; }
    label { display: block; font-size: 12px; font-weight: 600; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    .field { margin-bottom: 18px; }
    .hint { font-size: 11px; color: #334155; margin-top: 5px; }
    input[type=password] {
      width: 100%; background: rgba(255,255,255,0.03); border: 1px solid #1e2a45;
      border-radius: 8px; color: #e2e8f0; font-size: 14px; font-family: 'Inter', sans-serif;
      padding: 10px 14px; outline: none; transition: border-color 0.2s, box-shadow 0.2s;
    }
    input:focus { border-color: #00f0ff; box-shadow: 0 0 0 3px rgba(0,240,255,0.12); }
    input::placeholder { color: #334155; }
    .btn-submit {
      width: 100%; padding: 11px; margin-top: 4px;
      background: linear-gradient(135deg, #00f0ff, #8b5cf6);
      border: none; border-radius: 8px; color: #000; font-size: 14px; font-weight: 700;
      font-family: 'Inter', sans-serif; cursor: pointer;
      box-shadow: 0 0 20px rgba(0,240,255,0.25); transition: all 0.2s;
    }
    .btn-submit:hover { box-shadow: 0 0 30px rgba(0,240,255,0.4); transform: translateY(-1px); }
    .back-link { text-align: center; margin-top: 20px; }
    .back-link a { font-size: 12px; color: #475569; text-decoration: none; }
    .back-link a:hover { color: #00f0ff; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo-wrap">
      <div class="logo-icon"><i class="bi bi-lock"></i></div>
      <div class="logo-title">Nova senha</div>
      <div class="logo-sub">Prospecto-IA</div>
    </div>

    <% if (erro) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i><%= erro %></div>
    <% } %>
    <% if (sucesso) { %>
    <div class="alert alert-success"><i class="bi bi-check-circle"></i><%= sucesso %></div>
    <% } %>

    <% if (token) { %>
    <form method="post" action="/redefinir-senha/<%= token %>">
      <div class="field">
        <label>Nova senha</label>
        <input type="password" name="senha" autofocus required minlength="6" autocomplete="new-password" placeholder="Mínimo 6 caracteres">
        <div class="hint">Mínimo 6 caracteres.</div>
      </div>
      <div class="field">
        <label>Confirmar senha</label>
        <input type="password" name="confirmacao" required minlength="6" autocomplete="new-password" placeholder="Repita a senha">
      </div>
      <button type="submit" class="btn-submit">
        <i class="bi bi-check-lg" style="margin-right:6px"></i>Salvar nova senha
      </button>
    </form>
    <% } %>

    <div class="back-link">
      <a href="/login"><i class="bi bi-arrow-left" style="margin-right:4px"></i>Voltar ao login</a>
    </div>
  </div>
</body>
</html>
