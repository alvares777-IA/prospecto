<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Prospecto-IA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    /* ── Variáveis Bootstrap ──────────────────────────────────── */
    :root {
      --bs-body-font-family: 'Inter', system-ui, sans-serif;
      --bs-body-bg:              #080c18;
      --bs-body-color:           #e2e8f0;
      --bs-border-color:         #1e2a45;
      --bs-border-radius:        10px;
      --bs-border-radius-sm:     7px;
      --bs-border-radius-lg:     12px;
      --bs-card-bg:              #0d1224;
      --bs-card-border-color:    #1e2a45;
      --bs-card-cap-bg:          rgba(255,255,255,0.02);
      --bs-card-color:           #e2e8f0;
      --bs-table-bg:             transparent;
      --bs-table-color:          #e2e8f0;
      --bs-table-striped-bg:     rgba(255,255,255,0.025);
      --bs-table-striped-color:  #e2e8f0;
      --bs-table-hover-bg:       rgba(0,240,255,0.04);
      --bs-table-hover-color:    #e2e8f0;
      --bs-table-border-color:   rgba(255,255,255,0.05);
      --bs-primary:              #00f0ff;
      --bs-primary-rgb:          0,240,255;
      --bs-secondary:            #475569;
      --bs-secondary-rgb:        71,85,105;
      --bs-success:              #10b981;
      --bs-success-rgb:          16,185,129;
      --bs-danger:               #ef4444;
      --bs-danger-rgb:           239,68,68;
      --bs-warning:              #fbbf24;
      --bs-warning-rgb:          251,191,36;
      --bs-info:                 #06b6d4;
      --bs-info-rgb:             6,182,212;
      --bs-link-color:           #00f0ff;
      --bs-link-color-rgb:       0,240,255;
      --neon-cyan:               #00f0ff;
      --neon-purple:             #8b5cf6;
      --surface:                 #0d1224;
      --surface2:                #111827;
      --border:                  #1e2a45;
    }

    /* ── Reset & base ────────────────────────────────────────── */
    * { box-sizing: border-box; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #080c18;
      color: #e2e8f0;
      min-height: 100vh;
    }

    /* scanline sutil */
    body::after {
      content: '';
      position: fixed; inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,240,255,0.008) 2px, rgba(0,240,255,0.008) 4px);
      pointer-events: none;
      z-index: 9998;
    }

    /* ── Sidebar ─────────────────────────────────────────────── */
    .sidebar {
      background: linear-gradient(180deg, #0d1224 0%, #080c18 100%);
      border-right: 1px solid #1e2a45;
    }
    @media (min-width: 992px) {
      .sidebar {
        width: 240px;
        position: relative;
      }
      .sidebar::after {
        content: '';
        position: absolute;
        top: 0; right: 0; width: 1px; height: 100%;
        background: linear-gradient(180deg, transparent 0%, rgba(0,240,255,0.25) 50%, transparent 100%);
        pointer-events: none;
      }
    }

    /* Logo */
    .neon-logo {
      display: flex; align-items: center; gap: 10px;
      padding: 8px;
      margin-bottom: 8px;
    }
    .neon-logo-icon {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple));
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; color: #000;
      box-shadow: 0 0 14px rgba(0,240,255,0.4);
      flex-shrink: 0;
    }
    .neon-logo-text {
      font-size: 14px; font-weight: 700; letter-spacing: 0.5px;
      background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Nav links */
    .sidebar .section-label {
      font-size: 9px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 1.8px;
      color: #334155;
      padding: .65rem .75rem .2rem;
    }
    .sidebar .nav-link {
      color: #64748b;
      border-radius: 8px;
      margin-bottom: 2px;
      padding: .5rem .75rem;
      font-size: 13.5px; font-weight: 500;
      transition: all 0.2s;
      display: flex; align-items: center; gap: 8px;
    }
    .sidebar .nav-link:hover { color: var(--neon-cyan); background: rgba(0,240,255,0.07); }
    .sidebar .nav-link.active {
      color: var(--neon-cyan);
      background: rgba(0,240,255,0.1);
      box-shadow: inset 3px 0 0 var(--neon-cyan);
      font-weight: 600;
    }

    /* User box */
    .neon-user-box {
      background: rgba(255,255,255,0.03);
      border: 1px solid #1e2a45;
      border-radius: 10px;
      padding: 10px 12px;
    }
    .neon-user-avatar {
      width: 32px; height: 32px;
      border-radius: 8px;
      background: linear-gradient(135deg, rgba(0,240,255,0.2), rgba(139,92,246,0.2));
      border: 1px solid rgba(0,240,255,0.25);
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700;
      color: var(--neon-cyan);
      flex-shrink: 0;
    }
    .neon-user-name { font-size: 12px; font-weight: 600; color: #e2e8f0; }
    .neon-user-role { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--neon-cyan); }

    /* ── Top bar (mobile) ────────────────────────────────────── */
    .top-bar {
      background: rgba(8,12,24,0.95) !important;
      border-bottom: 1px solid #1e2a45 !important;
      backdrop-filter: blur(12px);
    }
    .top-bar .navbar-toggler { border: 1px solid #1e2a45; }
    .top-bar .navbar-toggler-icon { filter: invert(1) brightness(0.6); }
    .top-bar .fw-bold { color: #e2e8f0 !important; }
    .top-bar .text-muted { color: #64748b !important; }

    /* ── Main content ────────────────────────────────────────── */
    .main-content { background: #080c18; min-height: 100vh; }

    /* ── Cards ───────────────────────────────────────────────── */
    .card {
      background: #0d1224 !important;
      border: 1px solid #1e2a45 !important;
      border-radius: 12px !important;
    }
    .card-body { color: #e2e8f0; }

    /* ── Buttons ─────────────────────────────────────────────── */
    .btn-primary {
      background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple)) !important;
      border: none !important;
      color: #000 !important;
      font-weight: 700 !important;
      box-shadow: 0 0 18px rgba(0,240,255,0.25) !important;
      transition: all 0.2s !important;
    }
    .btn-primary:hover, .btn-primary:focus {
      box-shadow: 0 0 28px rgba(0,240,255,0.45) !important;
      transform: translateY(-1px);
      color: #000 !important;
    }
    .btn-outline-secondary {
      background: transparent !important;
      border: 1px solid rgba(0,240,255,0.25) !important;
      color: #94a3b8 !important;
    }
    .btn-outline-secondary:hover {
      background: rgba(0,240,255,0.07) !important;
      border-color: rgba(0,240,255,0.5) !important;
      color: var(--neon-cyan) !important;
    }
    .btn-outline-danger {
      background: transparent !important;
      border: 1px solid rgba(239,68,68,0.3) !important;
      color: #f87171 !important;
    }
    .btn-outline-danger:hover {
      background: rgba(239,68,68,0.1) !important;
      border-color: rgba(239,68,68,0.6) !important;
      color: #fca5a5 !important;
    }
    .btn-outline-danger:disabled {
      background: transparent !important;
      border-color: rgba(239,68,68,0.15) !important;
      color: rgba(248,113,113,0.3) !important;
    }
    .btn-sm { font-size: 12px; padding: 5px 10px; }

    /* ── Forms ───────────────────────────────────────────────── */
    .form-control, .form-select {
      background: rgba(13,18,36,0.8) !important;
      border: 1px solid #1e2a45 !important;
      color: #e2e8f0 !important;
      border-radius: 8px !important;
    }
    .form-control:focus, .form-select:focus {
      background: #0d1224 !important;
      border-color: var(--neon-cyan) !important;
      box-shadow: 0 0 0 3px rgba(0,240,255,0.12) !important;
      color: #e2e8f0 !important;
    }
    .form-control::placeholder { color: #334155 !important; }
    .form-select option { background: #0d1224; color: #e2e8f0; }
    .form-label { color: #94a3b8 !important; font-size: 13px; }
    .form-label.fw-semibold { color: #cbd5e1 !important; }
    .form-text { color: #334155 !important; }
    textarea.form-control { resize: vertical; }
    input[type=number].form-control { -moz-appearance: textfield; }
    input[type=number].form-control::-webkit-outer-spin-button,
    input[type=number].form-control::-webkit-inner-spin-button { -webkit-appearance: none; }

    /* ── Tables ──────────────────────────────────────────────── */
    .table { color: #e2e8f0 !important; }
    .table > :not(caption) > * > * {
      background: transparent !important;
      color: #e2e8f0 !important;
      border-bottom-color: rgba(255,255,255,0.04) !important;
    }
    .table-hover > tbody > tr:hover > * { background: rgba(0,240,255,0.04) !important; }
    thead.table-light th, .table thead.table-light > tr > th,
    .table > thead > tr > th {
      background: rgba(255,255,255,0.02) !important;
      color: #334155 !important;
      font-size: 10px !important;
      font-weight: 700 !important;
      text-transform: uppercase !important;
      letter-spacing: 1px !important;
      border-bottom: 1px solid #1e2a45 !important;
    }

    /* ── Badges ──────────────────────────────────────────────── */
    .badge { font-weight: 600; border-radius: 6px; padding: 4px 10px; }
    .badge.bg-secondary { background: rgba(71,85,105,0.25) !important; color: #94a3b8 !important; border: 1px solid rgba(71,85,105,0.4); }
    .badge.bg-primary   { background: rgba(0,240,255,0.15) !important; color: var(--neon-cyan) !important; border: 1px solid rgba(0,240,255,0.3); }
    .badge.bg-success   { background: rgba(16,185,129,0.15) !important; color: #10b981 !important; border: 1px solid rgba(16,185,129,0.3); }
    .badge.bg-danger    { background: rgba(239,68,68,0.15) !important; color: #f87171 !important; border: 1px solid rgba(239,68,68,0.3); }
    .badge.bg-warning   { background: rgba(251,191,36,0.15) !important; color: #fbbf24 !important; border: 1px solid rgba(251,191,36,0.3); color: #fbbf24 !important; }
    .badge.bg-info      { background: rgba(6,182,212,0.15) !important; color: #22d3ee !important; border: 1px solid rgba(6,182,212,0.3); }

    /* Status badges (leads) */
    .badge.s-novo         { background: rgba(0,240,255,0.12) !important; color: #00f0ff !important; border: 1px solid rgba(0,240,255,0.3); }
    .badge.s-contactado   { background: rgba(59,130,246,0.15) !important; color: #60a5fa !important; border: 1px solid rgba(59,130,246,0.3); }
    .badge.s-interessado  { background: rgba(251,191,36,0.15) !important; color: #fbbf24 !important; border: 1px solid rgba(251,191,36,0.3); }
    .badge.s-convertido   { background: rgba(16,185,129,0.15) !important; color: #10b981 !important; border: 1px solid rgba(16,185,129,0.3); }
    .badge.s-descartado   { background: rgba(71,85,105,0.15) !important; color: #94a3b8 !important; border: 1px solid rgba(71,85,105,0.3); }
    .badge.s-sem_interesse{ background: rgba(249,115,22,0.15) !important; color: #f97316 !important; border: 1px solid rgba(249,115,22,0.3); }

    /* ── Alerts ──────────────────────────────────────────────── */
    .alert-danger {
      background: rgba(239,68,68,0.08) !important;
      border: 1px solid rgba(239,68,68,0.3) !important;
      color: #fca5a5 !important; border-radius: 10px !important;
    }
    .alert-success {
      background: rgba(16,185,129,0.08) !important;
      border: 1px solid rgba(16,185,129,0.3) !important;
      color: #6ee7b7 !important; border-radius: 10px !important;
    }
    .alert-success .alert-heading { color: #34d399 !important; }
    .alert-dismissible .btn-close { filter: invert(1) brightness(0.7); }

    /* ── Text helpers ────────────────────────────────────────── */
    h1,h2,h3,h4,h5,h6 { color: #e2e8f0 !important; }
    .text-muted { color: #475569 !important; }
    .text-success { color: #10b981 !important; }
    .text-danger  { color: #f87171 !important; }
    .text-warning { color: #fbbf24 !important; }
    .text-info    { color: #22d3ee !important; }
    .text-dark    { color: #e2e8f0 !important; }
    .text-primary { color: var(--neon-cyan) !important; }
    a { color: var(--neon-cyan); }
    a:hover { color: #67e8f9; }
    a.text-decoration-none { color: #e2e8f0; }
    a.text-decoration-none:hover { color: var(--neon-cyan); }
    .small, small { color: #64748b; }
    .border-top { border-top-color: #1e2a45 !important; }
    .border-secondary { border-color: #1e2a45 !important; }

    /* ── Pagination ──────────────────────────────────────────── */
    .btn-outline-secondary.btn-sm[href*="pagina"] {
      border-color: #1e2a45 !important; color: #64748b !important;
    }
  </style>
</head>
<body>
<div class="d-flex">

  <!-- ── Sidebar ─────────────────────────────────────────────── -->
  <div class="offcanvas-lg offcanvas-start sidebar d-flex flex-column flex-shrink-0"
       id="sidebar" tabindex="-1" style="width:240px">
    <div class="offcanvas-header d-lg-none" style="border-bottom:1px solid #1e2a45">
      <div class="neon-logo">
        <div class="neon-logo-icon"><i class="bi bi-bullseye"></i></div>
        <span class="neon-logo-text">PROSPECTO-IA</span>
      </div>
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" data-bs-target="#sidebar"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column p-3">

      <div class="d-none d-lg-flex neon-logo mb-3">
        <div class="neon-logo-icon"><i class="bi bi-bullseye"></i></div>
        <span class="neon-logo-text">PROSPECTO-IA</span>
      </div>

      <nav class="nav flex-column flex-grow-1">
        <a class="nav-link <%= page==='dashboard' ? 'active' : '' %>" href="/dashboard">
          <i class="bi bi-speedometer2"></i>Dashboard
        </a>

        <div class="section-label">Leads</div>
        <a class="nav-link <%= page==='leads-lista' ? 'active' : '' %>" href="/leads">
          <i class="bi bi-people"></i>Listar
        </a>
        <a class="nav-link <%= page==='leads-novo' ? 'active' : '' %>" href="/leads/novo">
          <i class="bi bi-person-plus"></i>Novo Lead
        </a>
        <a class="nav-link <%= page==='leads-upload' ? 'active' : '' %>" href="/leads/upload">
          <i class="bi bi-cloud-upload"></i>Upload
        </a>

        <div class="section-label">Administração</div>
        <a class="nav-link <%= page==='whatsapp' ? 'active' : '' %>" href="/whatsapp">
          <i class="bi bi-whatsapp"></i>WhatsApp
        </a>
        <% if (['admin','supervisor'].includes(usuario.perfil)) { %>
        <a class="nav-link <%= page==='campanhas' ? 'active' : '' %>" href="/campanhas">
          <i class="bi bi-megaphone"></i>Campanhas
        </a>
        <% } %>
        <% if (usuario.perfil === 'admin') { %>
        <a class="nav-link <%= page==='usuarios' ? 'active' : '' %>" href="/usuarios">
          <i class="bi bi-shield-person"></i>Usuários
        </a>
        <a class="nav-link <%= page==='swagger' ? 'active' : '' %>" href="/api-docs">
          <i class="bi bi-shield-person"></i>Swagger
        </a>
        <% } %>
      </nav>

      <div class="mt-auto pt-3" style="border-top:1px solid #1e2a45">
        <a href="/perfil" class="d-block text-decoration-none neon-user-box mb-2"
           style="transition:border-color 0.2s"
           onmouseover="this.style.borderColor='rgba(0,240,255,0.4)'"
           onmouseout="this.style.borderColor='#1e2a45'">
          <div class="d-flex align-items-center gap-2">
            <div class="neon-user-avatar" style="overflow:hidden">
              <% if (usuario.avatar) { %>
              <img src="<%= usuario.avatar %>" alt="avatar"
                   style="width:32px;height:32px;object-fit:cover;border-radius:8px;display:block">
              <% } else { %>
              <%= usuario.nome.charAt(0).toUpperCase() %>
              <% } %>
            </div>
            <div class="overflow-hidden flex-grow-1">
              <div class="neon-user-name text-truncate"><%= usuario.nome %></div>
              <div class="neon-user-role"><%= usuario.perfil %></div>
            </div>
            <i class="bi bi-gear-fill" style="color:#334155;font-size:11px;flex-shrink:0"></i>
          </div>
        </a>
        <form method="post" action="/logout">
          <button class="btn btn-outline-secondary btn-sm w-100" style="font-size:11px">
            <i class="bi bi-box-arrow-right me-1"></i>Sair
          </button>
        </form>
      </div>

    </div>
  </div>

  <!-- ── Conteúdo principal ───────────────────────────────────── -->
  <div class="main-content flex-grow-1" style="min-width:0;display:flex;flex-direction:column">

    <!-- Barra mobile -->
    <nav class="navbar top-bar px-3 d-lg-none sticky-top" style="z-index:100">
      <button class="navbar-toggler border-0 p-1" type="button"
              data-bs-toggle="offcanvas" data-bs-target="#sidebar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <span class="fw-bold" style="color:#e2e8f0">
        <i class="bi bi-bullseye me-1" style="color:var(--neon-cyan)"></i>Prospecto-IA
      </span>
      <span class="text-muted small"><%= usuario.nome.split(' ')[0] %></span>
    </nav>

    <div class="p-3 p-lg-4 flex-grow-1">
      <% if (flash && flash.sucesso) { %>
      <div class="alert alert-success alert-dismissible fade show shadow-sm mb-3" role="alert">
        <i class="bi bi-check-circle me-2"></i><%= flash.sucesso %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      <% } %>
      <% if (flash && flash.erro) { %>
      <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-3" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i><%= flash.erro %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      <% } %>
      <%- body %>
    </div>
  </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
