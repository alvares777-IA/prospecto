<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Prospecto-IA</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    body { background: #f0f2f5; }
    .sidebar { width: 240px; background: #1e293b; }
    .sidebar .nav-link { color: #94a3b8; border-radius: 6px; margin-bottom: 2px; padding: .5rem .75rem; }
    .sidebar .nav-link:hover { color: #fff; background: #334155; }
    .sidebar .nav-link.active { color: #fff; background: #2563eb; }
    .sidebar .section-label { font-size: .68rem; text-transform: uppercase; color: #64748b; font-weight: 600; padding: .75rem .75rem .25rem; }
    .main-content { flex: 1; min-width: 0; display: flex; flex-direction: column; min-height: 100vh; }
    .top-bar { background: #fff; border-bottom: 1px solid #e2e8f0; }
    .badge.s-novo        { background: #3b82f6; }
    .badge.s-contactado  { background: #06b6d4; }
    .badge.s-interessado { background: #f59e0b; }
    .badge.s-convertido  { background: #22c55e; }
    .badge.s-descartado  { background: #94a3b8; }
  </style>
</head>
<body>
<div class="d-flex">

  <!-- ── Sidebar ─────────────────────────────────────────────── -->
  <div class="offcanvas-lg offcanvas-start sidebar d-flex flex-column flex-shrink-0"
       id="sidebar" tabindex="-1" style="width:240px">
    <div class="offcanvas-header d-lg-none">
      <span class="text-white fw-bold fs-6"><i class="bi bi-bullseye text-primary me-2"></i>Prospecto-IA</span>
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" data-bs-target="#sidebar"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column p-3">
      <div class="d-none d-lg-flex align-items-center text-white fw-bold mb-4 mt-1">
        <i class="bi bi-bullseye text-primary fs-5 me-2"></i>Prospecto-IA
      </div>

      <nav class="nav flex-column flex-grow-1">
        <a class="nav-link <%= page==='dashboard' ? 'active' : '' %>" href="/dashboard">
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>

        <div class="section-label">Leads</div>
        <a class="nav-link <%= page==='leads-lista' ? 'active' : '' %>" href="/leads">
          <i class="bi bi-people me-2"></i>Listar
        </a>
        <a class="nav-link <%= page==='leads-novo' ? 'active' : '' %>" href="/leads/novo">
          <i class="bi bi-person-plus me-2"></i>Novo Lead
        </a>
        <a class="nav-link <%= page==='leads-upload' ? 'active' : '' %>" href="/leads/upload">
          <i class="bi bi-cloud-upload me-2"></i>Upload
        </a>

        <% if (usuario.perfil === 'admin') { %>
        <div class="section-label">Administração</div>
        <a class="nav-link <%= page==='usuarios' ? 'active' : '' %>" href="/usuarios">
          <i class="bi bi-shield-person me-2"></i>Usuários
        </a>
        <a class="nav-link <%= page==='whatsapp' ? 'active' : '' %>" href="/whatsapp">
          <i class="bi bi-whatsapp me-2"></i>WhatsApp
        </a>
        <% } %>
      </nav>

      <div class="mt-auto pt-3 border-top border-secondary">
        <div class="text-truncate text-light small mb-2">
          <i class="bi bi-person-circle me-1"></i><%= usuario.nome %>
          <span class="badge bg-secondary ms-1" style="font-size:.6rem;text-transform:uppercase"><%= usuario.perfil %></span>
        </div>
        <form method="post" action="/logout">
          <button class="btn btn-outline-secondary btn-sm w-100">
            <i class="bi bi-box-arrow-right me-1"></i>Sair
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- ── Conteúdo principal ───────────────────────────────────── -->
  <div class="main-content">

    <!-- Barra superior (apenas mobile) -->
    <nav class="navbar top-bar px-3 d-lg-none sticky-top">
      <button class="navbar-toggler border-0 p-1" type="button"
              data-bs-toggle="offcanvas" data-bs-target="#sidebar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <span class="fw-bold"><i class="bi bi-bullseye text-primary me-1"></i>Prospecto-IA</span>
      <span class="text-muted small"><%= usuario.nome.split(' ')[0] %></span>
    </nav>

    <div class="p-3 p-lg-4">
      <% if (flash && flash.sucesso) { %>
      <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle me-2"></i><%= flash.sucesso %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      <% } %>
      <% if (flash && flash.erro) { %>
      <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i><%= flash.erro %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      <% } %>
      <%- body %>
    </div>
  </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
