<h5 class="mb-4" style="font-weight:700;letter-spacing:-0.3px">
  <i class="bi bi-speedometer2 me-2" style="color:#00f0ff"></i>Dashboard
</h5>

<%
const cards = [
  { key: 'novo',        label: 'Novos',        icon: 'person-plus',  color: '#00f0ff'  },
  { key: 'contactado',  label: 'Contactados',  icon: 'chat-dots',    color: '#60a5fa'  },
  { key: 'interessado', label: 'Interessados', icon: 'star',         color: '#fbbf24'  },
  { key: 'convertido',  label: 'Convertidos',  icon: 'check-circle', color: '#10b981'  },
  { key: 'descartado',  label: 'Descartados',  icon: 'x-circle',     color: '#94a3b8'  },
];

const STATUS_LABELS = {
  novo:'Novos', contactado:'Contactados', interessado:'Interessados',
  convertido:'Convertidos', descartado:'Descartados', sem_interesse:'Sem interesse',
};
const STATUS_CORES = {
  novo:'#00f0ff', contactado:'#60a5fa', interessado:'#fbbf24',
  convertido:'#10b981', descartado:'#475569', sem_interesse:'#f97316',
};
const STATUS_ORDER = ['novo','contactado','interessado','convertido','descartado','sem_interesse'];
%>

<!-- Cards de resumo -->
<div class="row g-3 mb-4">
  <div class="col-6 col-sm-4 col-lg-2">
    <div class="card border-0 h-100" style="border-top:2px solid #00f0ff !important;box-shadow:0 0 20px rgba(0,240,255,0.08)">
      <div class="card-body text-center py-3">
        <i class="bi bi-people fs-4" style="color:#00f0ff"></i>
        <div class="fw-bold fs-3 mt-1" style="color:#00f0ff"><%= geral %></div>
        <div class="small" style="color:#475569;font-size:10px;text-transform:uppercase;letter-spacing:1px">Total</div>
      </div>
    </div>
  </div>
  <% for (const c of cards) { %>
  <div class="col-6 col-sm-4 col-lg-2">
    <a href="/leads?status=<%= c.key %>" class="card border-0 h-100 text-decoration-none"
       style="border-top:2px solid <%= c.color %> !important;transition:transform 0.2s,box-shadow 0.2s"
       onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 0 20px '+'<%= c.color %>'+'22'"
       onmouseout="this.style.transform='';this.style.boxShadow=''">
      <div class="card-body text-center py-3">
        <i class="bi bi-<%= c.icon %> fs-4" style="color:<%= c.color %>"></i>
        <div class="fw-bold fs-3 mt-1" style="color:<%= c.color %>"><%= totais[c.key] || 0 %></div>
        <div class="small" style="color:#475569;font-size:10px;text-transform:uppercase;letter-spacing:1px"><%= c.label %></div>
      </div>
    </a>
  </div>
  <% } %>
</div>

<!-- Botões de ação -->
<div class="d-flex flex-wrap gap-2 mb-4">
  <a href="/leads"        class="btn btn-primary"><i class="bi bi-people me-2"></i>Ver todos os leads</a>
  <a href="/leads/novo"   class="btn btn-outline-secondary"><i class="bi bi-person-plus me-2"></i>Novo Lead</a>
  <a href="/leads/upload" class="btn btn-outline-secondary"><i class="bi bi-cloud-upload me-2"></i>Upload</a>
</div>

<!-- Gráficos -->
<div class="row g-3">
  <div class="col-12 col-lg-6">
    <div class="card border-0">
      <div class="card-body p-4">
        <div class="small mb-3" style="color:#334155;text-transform:uppercase;letter-spacing:1.2px;font-weight:700;font-size:10px">
          <i class="bi bi-bar-chart me-1" style="color:#00f0ff"></i>Situação geral dos leads
        </div>
        <canvas id="chartGeral" height="220"></canvas>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card border-0">
      <div class="card-body p-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="small" style="color:#334155;text-transform:uppercase;letter-spacing:1.2px;font-weight:700;font-size:10px">
            <i class="bi bi-calendar-range me-1" style="color:#8b5cf6"></i>Leads criados nos últimos
          </div>
          <div class="d-flex align-items-center gap-2">
            <input type="number" id="inputDias" class="form-control form-control-sm text-center"
                   value="30" min="1" max="365" style="width:64px;font-weight:700;color:#00f0ff">
            <span style="font-size:12px;color:#475569">dias</span>
          </div>
        </div>
        <canvas id="chartPeriodo" height="220"></canvas>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
(function () {
  const STATUS_ORDER  = <%- JSON.stringify(STATUS_ORDER) %>;
  const STATUS_LABELS = <%- JSON.stringify(STATUS_LABELS) %>;
  const STATUS_CORES  = <%- JSON.stringify(STATUS_CORES) %>;
  const totaisRaw     = <%- JSON.stringify(totais) %>;

  const labels = STATUS_ORDER.map(s => STATUS_LABELS[s]);
  const cores  = STATUS_ORDER.map(s => STATUS_CORES[s]);

  function buildDataset(totaisObj) {
    return STATUS_ORDER.map(s => totaisObj[s] || 0);
  }

  const opcoesBase = {
    responsive: true,
    plugins: {
      legend: { display: false },
      tooltip: {
        backgroundColor: '#0d1224',
        borderColor: '#1e2a45',
        borderWidth: 1,
        titleColor: '#94a3b8',
        bodyColor: '#e2e8f0',
        callbacks: {
          label: ctx => ` ${ctx.parsed.y} lead${ctx.parsed.y !== 1 ? 's' : ''}`
        }
      }
    },
    scales: {
      y: {
        beginAtZero: true,
        ticks: { precision: 0, color: '#334155', font: { family: 'Inter', size: 11 } },
        grid: { color: '#1e2a45' }
      },
      x: {
        ticks: { color: '#475569', font: { family: 'Inter', size: 11 } },
        grid: { display: false }
      }
    }
  };

  new Chart(document.getElementById('chartGeral'), {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        data: buildDataset(totaisRaw),
        backgroundColor: cores.map(c => c + '30'),
        borderColor: cores,
        borderWidth: 2,
        borderRadius: 6,
        borderSkipped: false,
        hoverBackgroundColor: cores.map(c => c + '55'),
      }]
    },
    options: opcoesBase
  });

  const chartPeriodo = new Chart(document.getElementById('chartPeriodo'), {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        data: labels.map(() => 0),
        backgroundColor: cores.map(c => c + '30'),
        borderColor: cores,
        borderWidth: 2,
        borderRadius: 6,
        borderSkipped: false,
        hoverBackgroundColor: cores.map(c => c + '55'),
      }]
    },
    options: opcoesBase
  });

  function carregarPeriodo(dias) {
    fetch(`/dashboard/periodo?dias=${dias}`)
      .then(r => r.json())
      .then(rows => {
        const map = {};
        rows.forEach(r => { map[r.status] = r.total; });
        chartPeriodo.data.datasets[0].data = buildDataset(map);
        chartPeriodo.update();
      });
  }

  carregarPeriodo(30);

  let timer;
  document.getElementById('inputDias').addEventListener('input', function () {
    clearTimeout(timer);
    const v = parseInt(this.value);
    if (v >= 1 && v <= 365) timer = setTimeout(() => carregarPeriodo(v), 400);
  });
})();
</script>
