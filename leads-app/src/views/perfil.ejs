<div class="d-flex align-items-center mb-4">
  <div class="me-3" style="
      width:44px; height:44px; border-radius:50%;
      border:2px solid rgba(0,240,255,0.35);
      box-shadow:0 0 14px rgba(0,240,255,0.12);
      overflow:hidden; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      background:linear-gradient(135deg,rgba(0,240,255,0.12),rgba(139,92,246,0.12));
      font-size:18px; font-weight:700; color:#00f0ff;">
    <% if (usuario_perfil.avatar) { %>
    <img src="<%= usuario_perfil.avatar %>?t=<%= Date.now() %>" alt="Avatar"
         style="width:100%;height:100%;object-fit:cover">
    <% } else { %>
    <%= usuario_perfil.nome.charAt(0).toUpperCase() %>
    <% } %>
  </div>
  <h5 class="mb-0" style="font-weight:700">Meu Perfil</h5>
</div>

<% if (erro) { %>
<div class="alert alert-danger mb-4"><i class="bi bi-exclamation-triangle me-2"></i><%= erro %></div>
<% } %>
<% if (sucesso) { %>
<div class="alert alert-success mb-4"><i class="bi bi-check-circle me-2"></i><%= sucesso %></div>
<% } %>

<div class="row g-4" style="max-width:760px">

  <!-- ── Avatar ─────────────────────────────────────────── -->
  <div class="col-12">
    <div class="card border-0">
      <div class="card-body p-4">
        <div class="small mb-4" style="color:#334155;text-transform:uppercase;letter-spacing:1.2px;font-weight:700;font-size:10px">
          <i class="bi bi-image me-1" style="color:#00f0ff"></i>Foto / Avatar
        </div>

        <div class="d-flex align-items-center gap-4 flex-wrap">
          <!-- Preview do avatar -->
          <div id="avatar-preview" style="
              width:88px; height:88px; border-radius:50%;
              border:2px solid rgba(0,240,255,0.35);
              box-shadow:0 0 20px rgba(0,240,255,0.15);
              overflow:hidden; flex-shrink:0;
              display:flex; align-items:center; justify-content:center;
              background:linear-gradient(135deg,rgba(0,240,255,0.12),rgba(139,92,246,0.12));
              font-size:32px; font-weight:700; color:#00f0ff;">
            <% if (usuario_perfil.avatar) { %>
            <img src="<%= usuario_perfil.avatar %>?t=<%= Date.now() %>" alt="Avatar"
                 style="width:100%;height:100%;object-fit:cover">
            <% } else { %>
            <%= usuario_perfil.nome.charAt(0).toUpperCase() %>
            <% } %>
          </div>

          <!-- Upload form -->
          <div class="flex-grow-1">
            <form method="post" action="/perfil/avatar" enctype="multipart/form-data" id="form-avatar">
              <label for="input-avatar" class="form-label">Selecionar nova foto</label>
              <div class="d-flex gap-2 align-items-center flex-wrap">
                <input type="file" name="avatar" id="input-avatar" class="form-control form-control-sm"
                       accept="image/jpeg,image/png,image/gif,image/webp"
                       style="max-width:280px" onchange="previewAvatar(this)">
                <button type="submit" class="btn btn-primary btn-sm">
                  <i class="bi bi-upload me-1"></i>Salvar foto
                </button>
              </div>
              <div style="font-size:11px;color:#334155;margin-top:6px">
                Formatos: JPEG, PNG, GIF, WebP · Tamanho máximo: 2MB
              </div>
            </form>

            <% if (usuario_perfil.avatar) { %>
            <form method="post" action="/perfil/avatar/remover" class="mt-2 d-inline"
                  onsubmit="return confirm('Remover foto de perfil?')">
              <button class="btn btn-sm btn-outline-danger" style="font-size:11px">
                <i class="bi bi-trash me-1"></i>Remover foto
              </button>
            </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Nome ───────────────────────────────────────────── -->
  <div class="col-12 col-md-6">
    <div class="card border-0 h-100">
      <div class="card-body p-4">
        <div class="small mb-4" style="color:#334155;text-transform:uppercase;letter-spacing:1.2px;font-weight:700;font-size:10px">
          <i class="bi bi-person me-1" style="color:#8b5cf6"></i>Nome de exibição
        </div>
        <form method="post" action="/perfil/nome">
          <div class="mb-3">
            <label class="form-label">Nome</label>
            <input type="text" name="nome" class="form-control"
                   value="<%= usuario_perfil.nome %>" required maxlength="120">
          </div>
          <div class="mb-3">
            <label class="form-label">E-mail</label>
            <input type="text" class="form-control" value="<%= usuario_perfil.email %>" disabled
                   style="color:#475569">
          </div>
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-check-lg me-1"></i>Salvar nome
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- ── Senha / Google ───────────────────────────────── -->
  <div class="col-12 col-md-6">
    <div class="card border-0 h-100">
      <div class="card-body p-4">

      <% if (usuario_perfil.tem_google && !usuario_perfil.tem_senha_local) { %>
        <!-- Conta Google sem senha local -->
        <div class="small mb-3" style="color:#334155;text-transform:uppercase;letter-spacing:1.2px;font-weight:700;font-size:10px">
          <i class="bi bi-google me-1" style="color:#ea4335"></i>Conta vinculada ao Google
        </div>
        <div class="mb-4 p-3" style="background:rgba(234,67,53,0.06);border:1px solid rgba(234,67,53,0.2);border-radius:8px;font-size:12px;color:#94a3b8">
          <i class="bi bi-info-circle me-1" style="color:#ea4335"></i>
          Seu acesso usa o Google. Para poder entrar com e-mail e senha,
          defina uma senha abaixo — o Google será desvinculado.
        </div>
        <form method="post" action="/perfil/desvincular-google">
          <div class="mb-3">
            <label class="form-label">Nova senha</label>
            <input type="password" name="senha_nova" class="form-control"
                   required minlength="8" placeholder="Mínimo 8 caracteres">
          </div>
          <div class="mb-3">
            <label class="form-label">Confirmar senha</label>
            <input type="password" name="senha_confirmacao" class="form-control"
                   required minlength="8" placeholder="Repita a nova senha">
          </div>
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-unlink me-1"></i>Desvincular Google e definir senha
          </button>
        </form>

      <% } else { %>
        <!-- Conta local (ou Google + senha já definida) -->
        <div class="small mb-4" style="color:#334155;text-transform:uppercase;letter-spacing:1.2px;font-weight:700;font-size:10px">
          <i class="bi bi-lock me-1" style="color:#fbbf24"></i>Trocar senha
        </div>
        <form method="post" action="/perfil/senha">
          <div class="mb-3">
            <label class="form-label">Senha atual</label>
            <input type="password" name="senha_atual" class="form-control"
                   required placeholder="Digite a senha atual">
          </div>
          <div class="mb-3">
            <label class="form-label">Nova senha</label>
            <input type="password" name="senha_nova" class="form-control"
                   required minlength="8" placeholder="Mínimo 8 caracteres">
          </div>
          <div class="mb-3">
            <label class="form-label">Confirmar nova senha</label>
            <input type="password" name="senha_confirmacao" class="form-control"
                   required minlength="8" placeholder="Repita a nova senha">
          </div>
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-shield-lock me-1"></i>Alterar senha
          </button>
        </form>
      <% } %>

      </div>
    </div>
  </div>

</div>

<script>
function previewAvatar(input) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    const preview = document.getElementById('avatar-preview');
    preview.innerHTML = '<img src="' + e.target.result + '" style="width:100%;height:100%;object-fit:cover">';
  };
  reader.readAsDataURL(input.files[0]);
}
</script>
