<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
  <h5 class="mb-0" style="font-weight:700">
    Campanhas
    <span class="badge" style="background:rgba(139,92,246,0.12);color:#8b5cf6;border:1px solid rgba(139,92,246,0.25);font-size:12px;font-weight:600"><%= campanhas.length %></span>
  </h5>
  <% if (['admin','supervisor'].includes(usuario.perfil)) { %>
  <a href="/campanhas/nova" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nova Campanha</a>
  <% } %>
</div>

<div class="card border-0">
  <div class="card-body p-0">
    <% if (campanhas.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-megaphone fs-1 d-block mb-2" style="color:#1e2a45"></i>
      <span style="color:#334155">Nenhuma campanha cadastrada.</span>
    </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th style="width:60px">#</th>
            <th>Descrição</th>
            <th class="d-none d-md-table-cell">Texto da mensagem</th>
            <th class="text-end pe-3">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% for (const c of campanhas) { %>
          <tr>
            <td style="color:#475569;font-size:13px"><%= c.id %></td>
            <td style="font-weight:500"><%= c.descricao %></td>
            <td class="d-none d-md-table-cell" style="color:#475569;font-size:13px;max-width:400px">
              <span class="text-truncate d-block" style="max-width:380px" title="<%= c.texto %>"><%= c.texto %></span>
            </td>
            <td class="text-end pe-3">
              <a href="/campanhas/<%= c.id %>/editar" class="btn btn-sm btn-outline-secondary me-1">
                <i class="bi bi-pencil"></i>
              </a>
              <% if (usuario.perfil === 'admin') { %>
              <form method="post" action="/campanhas/<%= c.id %>/excluir" class="d-inline"
                    onsubmit="return confirm('Excluir a campanha #<%= c.id %>?')">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
              <% } %>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>
