<div class="d-flex align-items-center mb-3">
  <a href="/leads" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i></a>
  <h5 class="mb-0" style="font-weight:700">Upload de Leads</h5>
</div>

<div class="card border-0" style="max-width:540px">
  <div class="card-body p-4">

    <% if (erro) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i><%= erro %></div>
    <% } %>

    <% if (resultado) { %>
    <div class="alert alert-success">
      <div class="fw-semibold mb-3" style="color:#6ee7b7;font-size:14px"><i class="bi bi-check-circle me-2"></i>Importação concluída</div>
      <div class="row g-2 text-center">
        <div class="col-6 col-sm-3">
          <div class="fw-bold fs-5" style="color:#e2e8f0"><%= resultado.total %></div>
          <div style="font-size:11px;color:#475569;text-transform:uppercase;letter-spacing:0.5px">Total</div>
        </div>
        <div class="col-6 col-sm-3">
          <div class="fw-bold fs-5" style="color:#10b981"><%= resultado.inseridos %></div>
          <div style="font-size:11px;color:#475569;text-transform:uppercase;letter-spacing:0.5px">Inseridos</div>
        </div>
        <div class="col-6 col-sm-3">
          <div class="fw-bold fs-5" style="color:#fbbf24"><%= resultado.duplicados %></div>
          <div style="font-size:11px;color:#475569;text-transform:uppercase;letter-spacing:0.5px">Duplicados</div>
        </div>
        <div class="col-6 col-sm-3">
          <div class="fw-bold fs-5" style="color:#f87171"><%= resultado.erros %></div>
          <div style="font-size:11px;color:#475569;text-transform:uppercase;letter-spacing:0.5px">Erros</div>
        </div>
      </div>
    </div>
    <% } %>

    <p style="color:#475569;font-size:13px;margin-bottom:6px">
      Aceita <strong style="color:#94a3b8">.csv</strong> e <strong style="color:#94a3b8">.xlsx</strong>. A primeira linha deve ser o cabeçalho.
    </p>
    <p style="color:#475569;font-size:13px;margin-bottom:20px">
      Colunas reconhecidas:
      <code style="color:#00f0ff;background:rgba(0,240,255,0.08);padding:1px 5px;border-radius:4px">telefone</code>,
      <code style="color:#00f0ff;background:rgba(0,240,255,0.08);padding:1px 5px;border-radius:4px">nome</code>,
      <code style="color:#00f0ff;background:rgba(0,240,255,0.08);padding:1px 5px;border-radius:4px">empresa</code>,
      <code style="color:#00f0ff;background:rgba(0,240,255,0.08);padding:1px 5px;border-radius:4px">cargo</code>,
      <code style="color:#00f0ff;background:rgba(0,240,255,0.08);padding:1px 5px;border-radius:4px">email</code>,
      <code style="color:#00f0ff;background:rgba(0,240,255,0.08);padding:1px 5px;border-radius:4px">origem</code>,
      <code style="color:#00f0ff;background:rgba(0,240,255,0.08);padding:1px 5px;border-radius:4px">observacoes</code>,
      <code style="color:#00f0ff;background:rgba(0,240,255,0.08);padding:1px 5px;border-radius:4px">campanha_id</code>
      <br><span style="color:#334155;font-size:12px">Variações aceitas: celular, whatsapp, fone, campanha, etc.</span>
    </p>

    <form method="post" action="/leads/upload" enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label">Arquivo</label>
        <input type="file" name="arquivo" class="form-control" accept=".csv,.xlsx,.xls" required>
      </div>
      <div class="mb-4">
        <label class="form-label">
          Campanha padrão
          <span style="color:#475569;font-size:12px;font-weight:400">(quando não especificada no arquivo)</span>
        </label>
        <select name="campanha_id" class="form-select">
          <% for (const c of campanhas) { %>
          <option value="<%= c.id %>" <%= c.id == defaultCampanha ? 'selected' : '' %>><%= c.id %> — <%= c.descricao %></option>
          <% } %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-cloud-upload me-2"></i>Importar
      </button>
    </form>

  </div>
</div>
