<div class="d-flex align-items-center mb-3">
  <a href="/leads" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i></a>
  <h5 class="mb-0" style="font-weight:700"><%= lead ? 'Editar Lead' : 'Novo Lead' %></h5>
</div>

<%
const STATUS_HIST_COR = {
  novo:          '#00f0ff',
  contactado:    '#60a5fa',
  interessado:   '#fbbf24',
  convertido:    '#10b981',
  descartado:    '#475569',
  sem_interesse: '#f97316',
};
function fmtData(d) {
  const dt = new Date(d);
  return dt.toLocaleDateString('pt-BR') + ' ' + dt.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
}
%>

<div class="card border-0" style="max-width:640px">
  <div class="card-body p-4">
    <% if (erro) { %>
    <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-2"></i><%= erro %></div>
    <% } %>

    <form method="post" action="<%= lead?.id ? '/leads/' + lead.id + '/editar' : '/leads/novo' %>">
      <div class="row g-3">

        <div class="col-12 col-sm-6">
          <label class="form-label">Telefone (WhatsApp) <span style="color:#f87171">*</span></label>
          <input type="tel" name="telefone" class="form-control"
                 value="<%= lead?.telefone || '' %>" required
                 placeholder="55 11 99999-9999">
        </div>

        <div class="col-12 col-sm-6">
          <label class="form-label">Status</label>
          <select name="status" class="form-select">
            <% for (const s of STATUS_VALIDOS) { %>
            <option value="<%= s %>" <%= (lead?.status || 'novo') === s ? 'selected' : '' %>>
              <%= s.charAt(0).toUpperCase() + s.slice(1) %>
            </option>
            <% } %>
          </select>
        </div>

        <div class="col-12 col-sm-6">
          <label class="form-label">Nome</label>
          <input type="text" name="nome" class="form-control" value="<%= lead?.nome || '' %>">
        </div>

        <div class="col-12 col-sm-6">
          <label class="form-label">Empresa</label>
          <input type="text" name="empresa" class="form-control" value="<%= lead?.empresa || '' %>">
        </div>

        <div class="col-12 col-sm-6">
          <label class="form-label">Cargo</label>
          <input type="text" name="cargo" class="form-control" value="<%= lead?.cargo || '' %>">
        </div>

        <div class="col-12 col-sm-6">
          <label class="form-label">E-mail</label>
          <input type="email" name="email" class="form-control" value="<%= lead?.email || '' %>">
        </div>

        <div class="col-12 col-sm-6">
          <label class="form-label">Origem</label>
          <input type="text" name="origem" class="form-control"
                 value="<%= lead?.origem || '' %>"
                 placeholder="ex: indicação, site, planilha">
        </div>

        <div class="col-12 col-sm-6">
          <label class="form-label">Campanha <span style="color:#f87171">*</span></label>
          <select name="campanha_id" class="form-select" required>
            <% for (const c of campanhas) { %>
            <option value="<%= c.id %>" <%= (lead?.campanha_id ?? defaultCampanha) == c.id ? 'selected' : '' %>>
              <%= c.id %> — <%= c.descricao %>
            </option>
            <% } %>
          </select>
        </div>

        <div class="col-12">
          <label class="form-label">Observações</label>
          <textarea name="observacoes" class="form-control" rows="3"><%= lead?.observacoes || '' %></textarea>
        </div>

        <div class="col-12 d-flex gap-2 pt-1">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>Salvar
          </button>
          <a href="/leads" class="btn btn-outline-secondary">Cancelar</a>
        </div>

      </div>
    </form>
  </div>
</div>

<% if (lead?.id) { %>
<div class="card border-0 mt-3" style="max-width:640px">
  <div class="card-body p-4">
    <div class="small mb-3" style="color:#334155;text-transform:uppercase;letter-spacing:1.2px;font-weight:700;font-size:10px">
      <i class="bi bi-clock-history me-1" style="color:#8b5cf6"></i>Histórico de status
    </div>
    <% if (historico.length === 0) { %>
    <p class="mb-0" style="color:#334155;font-size:13px">Nenhuma alteração de status registrada ainda.</p>
    <% } else { %>
    <div class="d-flex flex-column gap-0" style="position:relative">
      <% historico.forEach((h, i) => {
           const cor = STATUS_HIST_COR[h.status_lead] || '#475569';
           const ultimo = i === historico.length - 1;
      %>
      <div class="d-flex align-items-start gap-3" style="position:relative">
        <div style="display:flex;flex-direction:column;align-items:center;width:20px;flex-shrink:0">
          <div style="width:10px;height:10px;border-radius:50%;background:<%= cor %>;margin-top:5px;flex-shrink:0;box-shadow:0 0 8px <%= cor %>88"></div>
          <% if (!ultimo) { %>
          <div style="width:2px;flex:1;background:#1e2a45;min-height:24px"></div>
          <% } %>
        </div>
        <div class="pb-3">
          <span class="badge s-<%= h.status_lead %> me-2">
            <%= h.status_lead.charAt(0).toUpperCase() + h.status_lead.slice(1).replace('_', ' ') %>
          </span>
          <span style="color:#475569;font-size:12px"><%= fmtData(h.dt_status) %></span>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>
<% } %>
