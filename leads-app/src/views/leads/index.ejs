<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
  <h5 class="mb-0">Leads <span class="badge bg-secondary fw-normal"><%= total %></span></h5>
  <div class="d-flex gap-2">
    <a href="/leads/upload" class="btn btn-outline-secondary btn-sm"><i class="bi bi-cloud-upload me-1"></i>Upload</a>
    <a href="/leads/novo" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Novo</a>
  </div>
</div>

<!-- Filtros -->
<form method="get" action="/leads" class="card border-0 shadow-sm mb-3">
  <div class="card-body p-3">
    <div class="row g-2">
      <div class="col-12 col-md-6">
        <input type="text" name="busca" class="form-control form-control-sm"
               placeholder="Buscar por nome, telefone ou empresa"
               value="<%= busca || '' %>">
      </div>
      <div class="col-8 col-md-4">
        <select name="status" class="form-select form-select-sm">
          <option value="">Todos os status</option>
          <% for (const s of STATUS_VALIDOS) { %>
          <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
          <% } %>
        </select>
      </div>
      <div class="col-4 col-md-2 d-flex gap-1">
        <button type="submit" class="btn btn-primary btn-sm flex-grow-1">Filtrar</button>
        <a href="/leads" class="btn btn-outline-secondary btn-sm" title="Limpar"><i class="bi bi-x-lg"></i></a>
      </div>
    </div>
  </div>
</form>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if (leads.length === 0) { %>
    <div class="text-center text-muted py-5">
      <i class="bi bi-people fs-1 d-block mb-2 opacity-25"></i>
      Nenhum lead encontrado.
    </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Nome</th>
            <th>Telefone</th>
            <th class="d-none d-md-table-cell">Empresa</th>
            <th>Status</th>
            <th class="text-end pe-3">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% for (const l of leads) { %>
          <tr>
            <td><%= l.nome || '—' %></td>
            <td>
              <a href="https://wa.me/<%= l.telefone.replace(/\D/g,'') %>"
                 target="_blank" class="text-decoration-none text-dark">
                <i class="bi bi-whatsapp text-success me-1"></i><%= l.telefone %>
              </a>
            </td>
            <td class="d-none d-md-table-cell text-muted small"><%= l.empresa || '—' %></td>
            <td>
              <span class="badge s-<%= l.status %>">
                <%= l.status.charAt(0).toUpperCase() + l.status.slice(1) %>
              </span>
            </td>
            <td class="text-end pe-3">
              <a href="/leads/<%= l.id %>/editar" class="btn btn-sm btn-outline-secondary me-1">
                <i class="bi bi-pencil"></i>
              </a>
              <% if (['admin','supervisor'].includes(usuario.perfil)) { %>
              <form method="post" action="/leads/<%= l.id %>/excluir" class="d-inline"
                    onsubmit="return confirm('Excluir o lead <%= (l.nome || l.telefone).replace(/'/g,"\\'") %>?')">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
              <% } %>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <% if (totalPaginas > 1) { %>
    <div class="d-flex justify-content-between align-items-center p-3 border-top">
      <small class="text-muted">Página <%= pagina %> de <%= totalPaginas %></small>
      <div class="d-flex gap-2">
        <% if (pagina > 1) { %>
        <a class="btn btn-sm btn-outline-secondary"
           href="?pagina=<%= pagina-1 %>&status=<%= encodeURIComponent(status||'') %>&busca=<%= encodeURIComponent(busca||'') %>">
          <i class="bi bi-chevron-left"></i>
        </a>
        <% } %>
        <% if (pagina < totalPaginas) { %>
        <a class="btn btn-sm btn-outline-secondary"
           href="?pagina=<%= pagina+1 %>&status=<%= encodeURIComponent(status||'') %>&busca=<%= encodeURIComponent(busca||'') %>">
          <i class="bi bi-chevron-right"></i>
        </a>
        <% } %>
      </div>
    </div>
    <% } %>
    <% } %>
  </div>
</div>
