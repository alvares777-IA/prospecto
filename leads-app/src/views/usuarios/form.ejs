<div class="d-flex align-items-center mb-3">
  <a href="/usuarios" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i></a>
  <h5 class="mb-0"><%= usuario ? 'Editar Usuário' : 'Novo Usuário' %></h5>
</div>

<div class="card border-0 shadow-sm" style="max-width:480px">
  <div class="card-body p-4">
    <% if (erro) { %>
    <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-2"></i><%= erro %></div>
    <% } %>

    <form method="post" action="<%= usuario?.id ? '/usuarios/' + usuario.id + '/editar' : '/usuarios/novo' %>">

      <div class="mb-3">
        <label class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
        <input type="text" name="nome" class="form-control"
               value="<%= usuario?.nome || '' %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">E-mail <span class="text-danger">*</span></label>
        <input type="email" name="email" class="form-control"
               value="<%= usuario?.email || '' %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">
          <%= usuario ? 'Nova Senha (vazio = manter atual)' : 'Senha *' %>
        </label>
        <input type="password" name="senha" class="form-control"
               minlength="8" <%= usuario ? '' : 'required' %>
               placeholder="Mínimo 8 caracteres">
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Perfil <span class="text-danger">*</span></label>
        <select name="perfil" class="form-select" required>
          <% for (const p of PERFIS) { %>
          <option value="<%= p %>" <%= (usuario?.perfil || '') === p ? 'selected' : '' %>>
            <%= p.charAt(0).toUpperCase() + p.slice(1) %>
          </option>
          <% } %>
        </select>
        <div class="form-text">
          Admin: acesso total &nbsp;|&nbsp; Supervisor: excluir leads &nbsp;|&nbsp; Operador: cadastrar/editar
        </div>
      </div>

      <% if (usuario) { %>
      <div class="mb-4">
        <label class="form-label fw-semibold">Status</label>
        <select name="ativo" class="form-select">
          <option value="true"  <%= usuario.ativo ? 'selected' : '' %>>Ativo</option>
          <option value="false" <%= !usuario.ativo ? 'selected' : '' %>>Inativo</option>
        </select>
      </div>
      <% } %>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-check-lg me-1"></i>Salvar
        </button>
        <a href="/usuarios" class="btn btn-outline-secondary">Cancelar</a>
      </div>

    </form>
  </div>
</div>
