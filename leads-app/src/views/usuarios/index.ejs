<div class="d-flex align-items-center justify-content-between mb-3">
  <h5 class="mb-0">Usuários</h5>
  <a href="/usuarios/novo" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Novo</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Nome</th>
          <th class="d-none d-md-table-cell">E-mail</th>
          <th>Perfil</th>
          <th>Status</th>
          <th class="text-end pe-3"></th>
        </tr>
      </thead>
      <tbody>
        <% for (const u of usuarios) { %>
        <tr>
          <td>
            <%= u.nome %>
            <div class="d-md-none text-muted small"><%= u.email %></div>
          </td>
          <td class="d-none d-md-table-cell text-muted small"><%= u.email %></td>
          <td>
            <span class="badge bg-secondary" style="text-transform:uppercase;font-size:.7rem"><%= u.perfil %></span>
          </td>
          <td>
            <% if (u.ativo) { %>
            <span class="badge bg-success">Ativo</span>
            <% } else { %>
            <span class="badge bg-danger">Inativo</span>
            <% } %>
          </td>
          <td class="text-end pe-3">
            <a href="/usuarios/<%= u.id %>/editar" class="btn btn-sm btn-outline-secondary me-1">
              <i class="bi bi-pencil"></i>
            </a>
            <% if (u.id !== usuario.id) { %>
            <form method="post" action="/usuarios/<%= u.id %>/excluir" class="d-inline"
                  onsubmit="return confirm('Excluir <%= u.nome.replace(/'/g, "\\'") %>? Esta ação não pode ser desfeita.')">
              <button class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash"></i>
              </button>
            </form>
            <% } else { %>
            <button class="btn btn-sm btn-outline-danger" disabled title="Você não pode excluir sua própria conta">
              <i class="bi bi-trash"></i>
            </button>
            <% } %>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
