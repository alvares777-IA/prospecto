<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Prospecto-IA</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    body { background: #1e293b; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
  </style>
</head>
<body>
  <div class="card border-0 shadow-lg" style="width:100%;max-width:380px">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <i class="bi bi-bullseye text-primary" style="font-size:2.5rem"></i>
        <h5 class="mt-2 mb-0 fw-bold">Prospecto-IA</h5>
        <small class="text-muted">Gestão de Leads</small>
      </div>

      <% if (erro) { %>
      <div class="alert alert-danger py-2 small">
        <i class="bi bi-exclamation-triangle me-1"></i><%= erro %>
      </div>
      <% } %>
      <% if (sucesso) { %>
      <div class="alert alert-success py-2 small">
        <i class="bi bi-check-circle me-1"></i><%= sucesso %>
      </div>
      <% } %>

      <form method="post" action="/login">
        <div class="mb-3">
          <label class="form-label fw-semibold">E-mail</label>
          <input type="email" name="email" class="form-control" autofocus required autocomplete="email">
        </div>
        <div class="mb-1">
          <label class="form-label fw-semibold">Senha</label>
          <input type="password" name="senha" class="form-control" required autocomplete="current-password">
        </div>
        <div class="text-end mb-4">
          <a href="/esqueci-senha" class="small text-muted">Esqueci minha senha</a>
        </div>
        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
        </button>
      </form>

      <% if (googleEnabled) { %>
      <div class="d-flex align-items-center my-3">
        <hr class="flex-grow-1"><span class="px-2 text-muted small">ou</span><hr class="flex-grow-1">
      </div>
      <a href="/auth/google" class="btn btn-outline-secondary w-100">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" class="me-2" style="vertical-align:-.2em">
          <path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.8 2.4 30.2 0 24 0 14.7 0 6.7 5.4 2.7 13.3l7.9 6.1C12.4 13.1 17.8 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.2-.4-4.7H24v9h12.7c-.6 3-2.3 5.5-4.8 7.2l7.6 5.9c4.4-4.1 7-10.1 7-17.4z"/>
          <path fill="#FBBC05" d="M10.6 28.6A14.9 14.9 0 0 1 9.5 24c0-1.6.3-3.2.8-4.6l-7.9-6.1A23.9 23.9 0 0 0 0 24c0 3.9.9 7.5 2.7 10.7l7.9-6.1z"/>
          <path fill="#34A853" d="M24 48c6.2 0 11.4-2 15.2-5.5l-7.6-5.9c-2 1.4-4.6 2.2-7.6 2.2-6.2 0-11.5-3.6-13.4-8.8l-7.9 6.1C6.7 42.6 14.7 48 24 48z"/>
        </svg>
        Entrar com Google
      </a>
      <% } %>

    </div>
  </div>
</body>
</html>
