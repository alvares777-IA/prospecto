<div class="d-flex align-items-center mb-4">
  <i class="bi bi-whatsapp fs-4 me-2" style="color:#10b981"></i>
  <h5 class="mb-0">WhatsApp</h5>
</div>

<div class="row g-4">

  <!-- Status card -->
  <div class="col-12 col-md-5">
    <div class="card border-0 h-100">
      <div class="card-body p-4">
        <div class="small mb-3" style="color:#334155;text-transform:uppercase;letter-spacing:1.2px;font-weight:700;font-size:10px">
          Status da Conexão
        </div>

        <div id="status-area">
          <% if (state === 'open') { %>
          <div class="d-flex align-items-center mb-3">
            <span class="badge bg-success p-2" style="border-radius:8px">
              <i class="bi bi-circle-fill me-1" style="font-size:8px"></i>Conectado
            </span>
          </div>
          <p class="mb-4" style="color:#64748b;font-size:13px">O WhatsApp está ativo e enviando mensagens normalmente.</p>
          <form method="post" action="/whatsapp/desconectar"
                onsubmit="return confirm('Deseja desconectar o WhatsApp? O bot será pausado.')">
            <button class="btn btn-outline-danger btn-sm">
              <i class="bi bi-power me-1"></i>Desconectar
            </button>
          </form>
          <% } else if (state === 'connecting') { %>
          <div class="d-flex align-items-center mb-3">
            <span class="badge p-2" style="background:rgba(251,191,36,0.15);border:1px solid rgba(251,191,36,0.3);color:#fbbf24;border-radius:8px">
              <i class="bi bi-circle-fill me-1" style="font-size:8px"></i>Aguardando QR Code
            </span>
          </div>
          <p style="color:#64748b;font-size:13px">Escaneie o QR Code ao lado com o WhatsApp do celular.</p>
          <% } else { %>
          <div class="d-flex align-items-center mb-3">
            <span class="badge p-2" style="background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:#f87171;border-radius:8px">
              <i class="bi bi-circle-fill me-1" style="font-size:8px"></i>Desconectado
            </span>
          </div>
          <p class="mb-4" style="color:#64748b;font-size:13px">Gere o QR Code ao lado para conectar um celular.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- QR Code card -->
  <div class="col-12 col-md-7">
    <div class="card border-0 h-100">
      <div class="card-body p-4 text-center">
        <div class="small mb-3" style="color:#334155;text-transform:uppercase;letter-spacing:1.2px;font-weight:700;font-size:10px">
          QR Code
        </div>

        <% if (state === 'open') { %>
        <div class="py-4" style="color:#10b981">
          <i class="bi bi-check-circle-fill" style="font-size:4rem;filter:drop-shadow(0 0 12px rgba(16,185,129,0.5))"></i>
          <p class="mt-3 mb-0 fw-semibold" style="color:#e2e8f0">Celular conectado</p>
          <p class="mt-1" style="color:#64748b;font-size:13px">O bot está operacional.</p>
        </div>
        <% } else { %>
        <div id="qr-area">

          <div id="qr-btn-area" class="py-4">
            <i class="bi bi-qr-code" style="font-size:3rem;color:#334155"></i>
            <p class="mt-3 mb-3" style="color:#64748b;font-size:13px">Clique para gerar o QR Code e conectar um celular.</p>
            <button id="btn-gerar-qr" class="btn btn-primary">
              <i class="bi bi-qr-code-scan me-2"></i>Gerar QR Code
            </button>
          </div>

          <div class="py-4 d-none" id="qr-loading" style="color:#64748b">
            <div class="spinner-border spinner-border-sm me-2" style="color:#00f0ff"></div>Aguardando QR Code...
          </div>

          <img id="qr-img" src="" alt="QR Code" class="img-fluid d-none"
               style="max-width:260px;border-radius:12px;border:2px solid #1e2a45;box-shadow:0 0 24px rgba(0,240,255,0.1)">
          <p class="mt-3 d-none" id="qr-hint" style="color:#64748b;font-size:13px">
            <i class="bi bi-phone me-1"></i>Abra o WhatsApp → Dispositivos conectados → Conectar dispositivo
          </p>

          <div class="mt-2 d-none" id="qr-error" style="color:#f87171;font-size:13px">
            Não foi possível gerar o QR Code. <a href="/whatsapp" style="color:#00f0ff">Recarregar</a>
          </div>

        </div>
        <% } %>

      </div>
    </div>
  </div>

</div>

<% if (state !== 'open') { %>
<script>
(function () {
  const img      = document.getElementById('qr-img');
  const loading  = document.getElementById('qr-loading');
  const hint     = document.getElementById('qr-hint');
  const errEl    = document.getElementById('qr-error');
  const btnArea  = document.getElementById('qr-btn-area');
  const btnGerar = document.getElementById('btn-gerar-qr');
  let attempts = 0, qrTimer = null, stTimer = null;

  async function fetchQR() {
    try {
      const r = await fetch('/whatsapp/qrcode');
      const d = await r.json();
      if (d.base64) {
        img.src = d.base64;
        img.classList.remove('d-none');
        hint.classList.remove('d-none');
        loading.classList.add('d-none');
        attempts = 0;
      } else {
        if (++attempts > 10) {
          loading.classList.add('d-none');
          errEl.classList.remove('d-none');
          clearInterval(qrTimer);
        }
      }
    } catch (_) {}
  }

  async function checkStatus() {
    try {
      const r = await fetch('/whatsapp/status');
      const d = await r.json();
      if (d.state === 'open') window.location.reload();
    } catch (_) {}
  }

  btnGerar.addEventListener('click', function () {
    btnArea.classList.add('d-none');
    loading.classList.remove('d-none');
    attempts = 0;
    fetchQR();
    qrTimer = setInterval(fetchQR, 5000);
    stTimer = setInterval(checkStatus, 4000);
  });
})();
</script>
<% } %>
